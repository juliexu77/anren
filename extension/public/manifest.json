{
  "manifest_version": 3,
  "name": "Anren Side Panel",
  "description": "Anren, where the mental load rests — a gentle companion beside your calendar.",
  "version": "0.1.0",
  "action": {
    "default_title": "Open Anren side panel",
    "default_icon": {
      "128": "icons/anren-128.png"
    }
  },
  "icons": {
    "128": "icons/anren-128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://calendar.google.com/*",
    "https://mail.google.com/*",
    "https://anren.lovable.app/*",
    "https://anren.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://anren.lovable.app/*",
        "https://anren.app/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "side-panel.html"
  }
}

