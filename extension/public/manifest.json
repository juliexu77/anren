{
  "manifest_version": 3,
  "name": "Anren Side Panel",
  "description": "Anren, where the mental load rests — a gentle companion beside your calendar.",
  "version": "0.1.0",
  "action": {
    "default_title": "Open Anren side panel",
    "default_icon": {
      "128": "icons/anren-128.png"
    }
  },
  "icons": {
    "128": "icons/anren-128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://calendar.google.com/*",
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "side-panel.html"
  }
}

